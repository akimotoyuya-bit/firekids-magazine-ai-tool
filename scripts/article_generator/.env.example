# AWS Bedrock 認証情報
# IAMユーザー「firekids-magazine-bedrock」のアクセスキー
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=firekids-magazine-generator-apne1-prod
S3_REGION=ap-northeast-1
VECTOR_CACHE_S3_KEY=cache/article_vector_cache.json
INVENTORY_S3_KEY=inventory/inventory.csv

# 使用するClaudeモデル（Bedrockで有効化したもの）
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# 通常運用の増分スキャン / 重複チェック優先期間
LOOKBACK_DAYS=60

# 記事生成アプリのポート（デフォルト8001）
GENERATOR_PORT=8001
