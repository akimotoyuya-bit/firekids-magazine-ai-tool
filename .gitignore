# ============================================
# 機密情報（絶対除外）
# ============================================
**/.env
**/.env.local
**/.env.production
!**/.env.example
*.key
*.pem
**/credentials*.json
**/service_account*.json
**/*secret*
**/*token*

# WordPressアプリケーションパスワードを含む可能性
scripts/wp_uploader_local/.env
scripts/wp_unpublisher_local/.env
deploy/env.production

# App Runner デプロイ用の生成JSON（実シークレットを含む・絶対に追跡しない）
deploy/_source-config*.json
deploy/_create-service*.json
deploy/_trust-policy*.json

# 過去記事 / ベクトルキャッシュ（運用データ・Git管理しない）
scripts/article_generator/*cache*.json
scripts/article_generator/past_articles_cache.json
scripts/article_generator/article_vector_cache.json

# 生成記事（コンテナ内のみ存在・Gitで管理しない）
articles/

# 画像インデックス（クロール生成物・Git管理しない）
data/fk_image_index.json
data/fk_image_index_raw.json

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ============================================
# OS / IDE
# ============================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

