# AWS App Runner デプロイ用環境変数テンプレート
# deploy.ps1 が scripts/*/.env から自動読み込みします
# 本番公開時は APP_USER / APP_PASSWORD を必ず設定してください

APP_USER=firekids
APP_PASSWORD=change-me-strong-password

AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

WP_BASE_URL=https://m.firekids.jp
WP_USER=
WP_APP_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
